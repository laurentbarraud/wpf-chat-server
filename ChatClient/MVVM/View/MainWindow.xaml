<Window x:Class="ChatClient.MVVM.View.MainWindow"
        x:Name="MainWindow1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ChatClient.MVVM.ViewModel"
        xmlns:local="clr-namespace:ChatClient.MVVM.View"
        xmlns:conv="clr-namespace:ChatClient.Converters"
        xmlns:selector="clr-namespace:ChatClient.MVVM.View"
        xmlns:settings="clr-namespace:ChatClient.Properties"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Chat client"
        Height="500"
        Width="800"
        Icon="/Resources/ChatClient-icon.ico"
        Loaded="MainWindow_Loaded"
        PreviewKeyDown="MainWindow_PreviewKeyDown"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <SolidColorBrush x:Key="SentBubbleBaseBrush"
                     Color="{Binding DataContext.SentBubbleBackgroundBrush.Color,
                                     ElementName=lstReceivedMessages}"/>

        <!-- Controls the background of the incoming messages area.
             Default: uses the application's theme (BackgroundBrush).
             When bubble mode is enabled and connected:
               - light theme  → soft cream background (#F4F3E8)
               - dark theme   → very dark brown background (#1E1D0D) -->
        <Style TargetType="Grid" x:Key="IncomingMessagesAreaBackgroundStyle">
            <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
        </Style>

        <!-- Connected field shine animation -->
        <Storyboard x:Key="ConnectedShineAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                     From="0.2" To="1.0" 
                     Duration="0:0:0.8"
                     AutoReverse="False"/>
        </Storyboard>

        <!-- Encryption icon style -->
        <Style x:Key="EncryptionStatusIconStyle" TargetType="Image">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TransformGroup>
                        <ScaleTransform/>
                        <TranslateTransform/>
                    </TransformGroup>
                </Setter.Value>
            </Setter>
            <Setter Property="Visibility"
              Value="{Binding EncryptMessages, Converter={StaticResource BoolToVis}}"/>
            <Setter Property="Source" Value="/Resources/syncing-keys.png"/>
            <Setter Property="ToolTip"
              Value="{Binding GettingMissingKeysToolTip}"/>
        </Style>

        <Style x:Key="ReceivedBubbleStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="6,2,40,2"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Opacity" Value="0.92"/>

            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black"
                              BlurRadius="6"
                              ShadowDepth="1"
                              Opacity="0.12"/>
                </Setter.Value>
            </Setter>

            <!-- Applies a vertical gradient to render received message bubbles -->
                <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">

                        <!-- Top: +6% (lighten) -->
                        <GradientStop Offset="0"
                          Color="{Binding Color,
                                          Source={StaticResource BackgroundBrush},
                                          Converter={StaticResource SlightLightenConverter},
                                          ConverterParameter=0.06}"/>

                        <!-- Middle: base -->
                        <GradientStop Offset="0.60"
                          Color="{Binding Color,
                                          Source={StaticResource BackgroundBrush}}"/>

                        <!-- Bottom: -3% (darken) -->
                        <GradientStop Offset="1"
                          Color="{Binding Color,
                                          Source={StaticResource BackgroundBrush},
                                          Converter={StaticResource SlightLightenConverter},
                                          ConverterParameter=-0.03}"/>

                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Received bubble template -->
        <DataTemplate x:Key="ReceivedBubbleTemplate">
            <Border Style="{StaticResource ReceivedBubbleStyle}"
                    IsHitTestVisible="False">
                <StackPanel>
                    <TextBlock Text="{Binding Sender}"
                       FontWeight="Bold"
                       FontSize="{Binding DataContext.DisplayFontSize,
                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                       Foreground="{DynamicResource ForegroundBrush}"/>

                    <TextBlock Text="{Binding Text}"
                       TextWrapping="Wrap"
                       FontFamily="Segoe UI Emoji"
                       FontSize="{Binding DataContext.DisplayFontSize,
                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                       Foreground="{DynamicResource ForegroundBrush}"
                       Margin="0,2,0,0"/>

                    <TextBlock Text="{Binding TimeStamp}"
                       FontSize="12"
                       Opacity="0.7"
                       HorizontalAlignment="Right"
                       Foreground="{DynamicResource ForegroundBrush}"
                       Margin="0,2,0,0"/>
                </StackPanel>

            </Border>
        </DataTemplate>

        <!-- Sent message bubble template -->
        <DataTemplate x:Key="SentBubbleTemplate">
            <Grid Margin="0,4,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Empty space on the left to push the bubble to the right -->
                <Border Grid.Column="0"/>

                <!-- Sent bubble -->
                <Border Grid.Column="1"
                        CornerRadius="14"
                        Margin="0,0,8,0"
                        Padding="10,6"
                        MaxWidth="420"
                        SnapsToDevicePixels="True"
                        Opacity="0.88">

                    <!-- Bubble shadow -->
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="Black"
                                              BlurRadius="8"
                                              ShadowDepth="1"
                                              Opacity="0.15"/>
                                </Setter.Value>
                            </Setter>

                            <Style.Triggers>
                                <!-- Stronger shadow on hover -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect Color="Black"
                                                      BlurRadius="12"
                                                      ShadowDepth="2"
                                                      Opacity="0.25"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <!-- Bubble gradient -->
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">

                            <!-- Top: +6% -->
                            <GradientStop Offset="0"
                                  Color="{Binding DataContext.SentBubbleBackgroundBrush.Color,
                                                  RelativeSource={RelativeSource AncestorType=ItemsControl},
                                                  Converter={StaticResource SlightLightenConverter},
                                                  ConverterParameter=0.06}"/>

                            <!-- Middle: base -->
                            <GradientStop Offset="0.60"
                                  Color="{Binding DataContext.SentBubbleBackgroundBrush.Color,
                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>

                            <!-- Bottom: -3% -->
                            <GradientStop Offset="1"
                                  Color="{Binding DataContext.SentBubbleBackgroundBrush.Color,
                                                  RelativeSource={RelativeSource AncestorType=ItemsControl},
                                                  Converter={StaticResource SlightLightenConverter},
                                                  ConverterParameter=-0.03}"/>

                        </LinearGradientBrush>
                    </Border.Background>

                    <!-- Bubble content -->
                    <StackPanel>

                        <!-- Main message text -->
                        <TextBlock Text="{Binding Text}"
                           TextWrapping="Wrap"
                           FontFamily="Segoe UI"
                           FontSize="{Binding DataContext.DisplayFontSize,
                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}">

                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>

                                    <Style.Triggers>
                                        
                                        <!-- Dark theme: forces white text -->
                                        <DataTrigger Binding="{Binding Source={x:Static settings:Settings.Default}, Path=AppTheme}"
                                             Value="dark">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    
                                    </Style.Triggers>
                                
                                </Style>
                            </TextBlock.Style>

                        </TextBlock>

                        <!-- Timestamp -->
                        <TextBlock Text="{Binding TimeStamp}"
                           FontSize="12"
                           Opacity="0.7"
                           HorizontalAlignment="Right"
                           Margin="0,2,0,0">

                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>

                                    <Style.Triggers>
                                        <!-- Dark theme: forces white timestamp -->
                                        <DataTrigger Binding="{Binding Source={x:Static settings:Settings.Default}, Path=AppTheme}"
                                             Value="dark">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>

                        </TextBlock>

                    </StackPanel>

                </Border>
            </Grid>
        </DataTemplate>

        <!-- System message style -->
        <Style x:Key="SystemBubbleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="Margin" Value="12"/>
        </Style>

        <!-- System message template -->
        <DataTemplate x:Key="SystemMessageTemplate">
            <TextBlock Text="{Binding Text}"
               Style="{StaticResource SystemBubbleStyle}"/>
        </DataTemplate>

        <!-- Template selector -->
        <selector:MessageTemplateSelector
                x:Key="MessageTemplateSelector"
                SentBubbleTemplate="{StaticResource SentBubbleTemplate}"
                ReceivedMessageTemplate="{StaticResource ReceivedBubbleTemplate}"
                SystemMessageTemplate="{StaticResource SystemMessageTemplate}"/>


        <!-- Watermark base style -->
        <Style x:Key="WatermarkFadeStyle" TargetType="TextBlock">
            <Setter Property="Opacity" Value="0.25"/>

            <Style.Triggers>
                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding IsConnected}" Value="False">
                    <Setter Property="Opacity" Value="0.25"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>
    
    <!-- Main layout -->
    <Grid x:Name="GrdMain"
          Background="{DynamicResource BackgroundBrush}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 0 : TopPanel -->
            <RowDefinition Height="*"/>
            <!-- 1 : Messages -->
            <RowDefinition Height="Auto"/>
            <!-- 2 : Splitter -->
            <RowDefinition x:Name="RowBottomRight"
                           Height="Auto"
                           MinHeight="16"/>
            <!-- 3 : Emoji bar -->
            <RowDefinition x:Name="RowInputArea"
                           Height="Auto"
                           MinHeight="34"/>
            <!-- 4 : Input field -->
        </Grid.RowDefinitions>

        <!-- Row 0 : Top panel -->
        <Grid x:Name="TopPanel"
              Grid.Row="0"
              Background="{DynamicResource BackgroundBrush}"
              Margin="6,4,6,4">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <!-- Center: Username | IP | Connect | List of users -->
                <ColumnDefinition Width="Auto"/>
                <!-- Right: Theme | Settings | Monitor | Spacer -->
            </Grid.ColumnDefinitions>

            <!-- Center area -->
            <Grid Grid.Column="0"
                  VerticalAlignment="Center"
                  HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Username -->
                    <ColumnDefinition Width="8"/>
                    <!-- spacing -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- IP -->
                    <ColumnDefinition Width="8"/>
                    <!-- spacing -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Connect -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Connected users list -->
                </Grid.ColumnDefinitions>

                <!-- Username -->
                <Border Grid.Column="0"
                        BorderBrush="{DynamicResource InputBorderBrush}"
                        BorderThickness="1"
                        Background="Transparent"
                        Focusable="True" 
                        KeyboardNavigation.IsTabStop="False"
                        Margin="0,0,6,0">
                    <Grid>
                        <TextBox x:Name="TxtUsername"
                                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="{Binding IsConnected}"
                                 Height="{Binding UsernameAndIPAddressInputFieldHeight}"
                                 FontSize="{Binding DisplayFontSize}"
                                 Foreground="{DynamicResource ForegroundBrush}"
                                 Background="Transparent"
                                 PreviewKeyDown="TxtUsername_PreviewKeyDown"
                                 BorderThickness="0"
                                 VerticalContentAlignment="Center"
                                 MinWidth="120"
                                 MinHeight="25"
                                 TabIndex="0"
                                 Panel.ZIndex="1"/>

                        <TextBlock x:Name="TxtUsernameWatermark"
                                   FontSize="{Binding DisplayFontSize}"
                                   FontStyle="Italic"
                                   Text="{Binding UsernameWatermark}"
                                   Margin="4,0,0,0"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Left"
                                   IsHitTestVisible="False"
                                   Panel.ZIndex="0">

                            <!-- Default watermark color -->
                            <TextBlock.Foreground>
                                <SolidColorBrush Color="{DynamicResource WatermarkColor}"/>
                            </TextBlock.Foreground>

                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource WatermarkFadeStyle}">

                                    <!-- Default state: watermark hidden -->
                                    <Setter Property="Visibility" Value="Collapsed"/>

                                    <Style.Triggers>

                                        <!-- Uses ForegroundBrush when dark theme has been set -->
                                        <DataTrigger Binding="{Binding Source={x:Static settings:Settings.Default}, Path=AppTheme}" Value="dark">
                                            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                                        </DataTrigger>

                                        <!-- If the TextBox is empty, shows the watermark -->
                                        <DataTrigger Binding="{Binding Text, ElementName=TxtUsername}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>

                                        <!-- If the TextBox has keyboard focus, hides the watermark -->
                                        <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=TxtUsername}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>

                                        <!-- If the TextBox is not empty, hides the watermark -->
                                        <!-- This ensures the watermark disappears as soon as the user types -->
                                        <DataTrigger Binding="{Binding Text, ElementName=TxtUsername}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>

                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>

                        </TextBlock>

                    </Grid>
                </Border>

                <!-- IP address -->
                <Border Grid.Column="2"
                        BorderBrush="{DynamicResource InputBorderBrush}"
                        BorderThickness="1"
                        Background="Transparent"
                        Margin="0,0,6,0">
                    <Grid>
                        <TextBox x:Name="TxtServerIPAddress"
                                 Text="{Binding CurrentIPDisplay}"
                                 IsReadOnly="{Binding IsConnected}"
                                 Height="{Binding UsernameAndIPAddressInputFieldHeight}"
                                 FontSize="{Binding DisplayFontSize}"
                                 Foreground="{DynamicResource ForegroundBrush}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 MinWidth="160"
                                 MinHeight="25"
                                 VerticalContentAlignment="Center"
                                 PreviewKeyDown="TxtServerIPAddress_PreviewKeyDown"
                                 TabIndex="1"
                                 Panel.ZIndex="1">

                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                                    <Setter Property="BorderThickness" Value="0"/>

                                    <Style.Triggers>

                                        <!-- Connected -->
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="IsReadOnly" Value="True"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                            <Setter Property="Opacity" Value="1.0"/>

                                            <DataTrigger.EnterActions>
                                                <!-- Play the same animation as in Legacy -->
                                                <BeginStoryboard Storyboard="{StaticResource ConnectedShineAnimation}"/>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>

                                        <!-- Disconnected -->
                                        <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                            <Setter Property="Opacity" Value="0.10"/>
                                        </DataTrigger>

                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>

                        </TextBox>

                        <TextBlock x:Name="TxtIPAddressWatermark"
                                   FontStyle="Italic"
                                   FontSize="{Binding DisplayFontSize}"
                                   Text="{Binding IPAddressWatermark}"
                                   Margin="4,0,0,0"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Left"
                                   IsHitTestVisible="False"
                                   Panel.ZIndex="0">

                            <!-- Default watermark color (light theme) -->
                            <TextBlock.Foreground>
                                <SolidColorBrush Color="{DynamicResource WatermarkColor}"/>
                            </TextBlock.Foreground>

                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource WatermarkFadeStyle}">

                                    <!-- Default state: watermark hidden -->
                                    <Setter Property="Visibility" Value="Collapsed"/>

                                    <Style.Triggers>

                                        <!-- Uses ForegroundBrush when dark theme has been set -->
                                        <DataTrigger Binding="{Binding Source={x:Static settings:Settings.Default}, Path=AppTheme}" Value="dark">
                                            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                                        </DataTrigger>

                                        <!-- If the field is empty and not focused and not connected, shows watermark -->
                                        <DataTrigger Binding="{Binding Text, ElementName=TxtServerIPAddress}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>

                                        <!-- If the field has keyboard focus, hides watermark -->
                                        <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=TxtServerIPAddress}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>

                                        <!-- If the user is connected, hides watermark -->
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>

                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>

                        </TextBlock>

                    </Grid>
                </Border>

                <!-- Connect button -->
                <Button Grid.Column="4"
                        x:Name="CmdConnectDisconnect"
                        Content="{Binding ConnectButtonText}"
                        Command="{Binding ConnectDisconnectCommand}"
                        Height="{Binding UsernameAndIPAddressInputFieldHeight}"
                        MinHeight="25"
                        FontSize="{Binding DisplayFontSize}"
                        Padding="10,4"
                        Background="{DynamicResource PrimaryBrush}"
                        Foreground="{DynamicResource ForegroundBrush}"
                        VerticalAlignment="Center"
                        TabIndex="2"
                        Cursor="Hand"/>

                <!-- Connected users list -->
                <Label Grid.Column="5"
                       x:Name="lblConnectedUsers"
                       Content="{x:Static sys:String.Empty}"
                       Foreground="{DynamicResource ForegroundBrush}"
                       Background="Transparent"
                       Margin="10,0,0,0"
                       VerticalAlignment="Center"
                       Cursor="Hand"
                       MouseEnter="lblConnectedUsers_MouseEnter" 
                       TabIndex="3"
                       Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibilityConverter}}"
                       IsEnabled="{Binding IsConnected}"/>

                <!-- Popup for connected users -->
                <Popup x:Name="ConnectedUsersPopup"
                       Placement="Bottom"
                       PlacementTarget="{Binding ElementName=lblConnectedUsers}"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       PopupAnimation="Fade"
                       HorizontalOffset="0"
                       VerticalOffset="4">

                    <Border Background="{DynamicResource BackgroundBrush}"
                            BorderBrush="{DynamicResource ForegroundBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="8"
                            IsHitTestVisible="False">

                        <!-- ItemsControl is a WPF control that displays a list of items without 
                        imposing any particular style 
                        This follows MVVM principle: the View does not know business logic; it simply binds. -->
                        <ItemsControl ItemsSource="{Binding ConnectedUsersView}">

                            <!-- Replaces the default panel with a vertical StackPanel, allowing 
                            to have control over the reorganization of the display -->
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <!-- Defines how each item in the ItemsControl is displayed. 
                            In this case, each connected user is represented by a TextBlock displaying 
                            their username -->
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Username}"
                                               Foreground="{DynamicResource ForegroundBrush}"
                                               Margin="2,1"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>

                        </ItemsControl>

                    </Border>
                </Popup>

            </Grid>

            <!-- Right area : Theme | Settings | Monitor | Spacer -->
            <Grid Grid.Column="1"
                  VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Theme toggle -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Settings -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Monitor -->
                </Grid.ColumnDefinitions>

                <!-- Theme toggle -->
                <ToggleButton x:Name="ThemeToggle"
                              Grid.Column="0"
                              Width="60"
                              Height="32"
                              VerticalAlignment="Center"
                              Command="{Binding ThemeToggleCommand}"
                              IsChecked="{Binding IsDarkTheme, Mode=TwoWay}"
                              TabIndex="3"
                              Cursor="Hand">

                    <ToggleButton.Template>
                        <ControlTemplate TargetType="{x:Type ToggleButton}">
                            <Grid>

                                <!-- Background -->
                                <Border x:Name="SwitchBackground"
                                        CornerRadius="16"
                                        Background="{DynamicResource BackgroundBrush}"
                                        BorderBrush="{DynamicResource PrimaryBrush}"
                                        BorderThickness="1" />

                                <!-- Thumb -->
                                <Grid x:Name="ThumbContainer"
                                      Width="28" Height="28"
                                      VerticalAlignment="Center"
                                      Margin="2,2,30,2">

                                    <Ellipse Fill="{DynamicResource PrimaryBrush}" />

                                    <Image x:Name="SwitchIcon"
                                           Source="/Resources/moon.png"
                                           Width="18" Height="18"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                                </Grid>
                            </Grid>

                            <ControlTemplate.Triggers>

                                <!-- Light theme -->
                                <DataTrigger Binding="{Binding IsDarkTheme}" Value="False">
                                    <Setter TargetName="SwitchBackground"
                                            Property="Background"
                                            Value="{DynamicResource BackgroundBrush}" />
                                    <Setter TargetName="SwitchBackground"
                                            Property="BorderBrush"
                                            Value="{DynamicResource PrimaryBrush}" />
                                    <Setter TargetName="SwitchIcon"
                                            Property="Source"
                                            Value="/Resources/moon.png" />
                                </DataTrigger>

                                <!-- Dark theme -->
                                <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                    <Setter TargetName="SwitchBackground"
                                            Property="Background"
                                            Value="Transparent" />
                                    <Setter TargetName="SwitchBackground"
                                            Property="BorderBrush"
                                            Value="{DynamicResource AccentBrush}" />
                                    <Setter TargetName="SwitchIcon"
                                            Property="Source"
                                            Value="/Resources/sun.png" />
                                </DataTrigger>

                                <!-- Thumb position -->
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="ThumbContainer"
                                            Property="Margin"
                                            Value="30,2,2,2" />
                                </Trigger>

                                <Trigger Property="IsChecked" Value="False">
                                    <Setter TargetName="ThumbContainer"
                                            Property="Margin"
                                            Value="2,2,30,2" />
                                </Trigger>

                                <!-- Modern hover -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="SwitchBackground"
                                            Property="Background"
                                            Value="{DynamicResource PrimaryBrush}" />
                                    <Setter TargetName="SwitchIcon"
                                            Property="Opacity"
                                            Value="0.9" />
                                </Trigger>

                                <!-- Disabled -->
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="SwitchBackground"
                                            Property="Opacity"
                                            Value="0.4" />
                                    <Setter TargetName="ThumbContainer"
                                            Property="Opacity"
                                            Value="0.4" />
                                </Trigger>

                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>

                <!-- Settings button -->
                <Button x:Name="CmdSettings"
                            Grid.Column="1"
                            Width="32"
                            Height="32"
                            Background="Transparent"
                            BorderThickness="0"
                            VerticalAlignment="Center"
                            Margin="5,0,5,0"
                            Click="CmdSettings_Click">

                    <Button.Style>
                        <Style TargetType="{x:Type Button}">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.8"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>

                    <Image Source="/Resources/settings.png"
                               Stretch="Uniform"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Button>

                <!-- Monitor button -->
                <Button x:Name="CmdMonitor"
                            Grid.Column="2"
                            Width="30"
                            Height="30"
                            Background="Transparent"
                            BorderThickness="0"
                            VerticalAlignment="Center"
                            Margin="10,0,5,0"
                            Click="CmdMonitor_Click"
                            Visibility="Collapsed"
                            Opacity="0">

                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>

                            <Style.Triggers>

                                <!-- Hover effect only -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.8"/>
                                </Trigger>

                            </Style.Triggers>
                        </Style>
                    </Button.Style>

                    <Image Source="/Resources/monitor.png"
                               Stretch="Uniform"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                </Button>

                <!-- Spacer -->
                <Border Grid.Column="3"/>
            </Grid>

        </Grid>

        <!-- Vertical Splitter -->
        <GridSplitter Grid.Column="1"
              Width="4"
              ResizeBehavior="PreviousAndNext"
              ShowsPreview="True"
              Background="Transparent"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"/>
        <!-- Right Panel -->
        <Grid x:Name="GrdRight"
              Grid.Column="2"
              Style="{StaticResource IncomingMessagesAreaBackgroundStyle}"
              UseLayoutRounding="True"
              SnapsToDevicePixels="True">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            
            <!-- Messages list -->
            <ListView x:Name="lstReceivedMessages"
                      Grid.Row="1"
                      Background="Transparent"
                      BorderThickness="0"
                      ItemsSource="{Binding Messages}"
                      ItemTemplateSelector="{StaticResource MessageTemplateSelector}">

                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,2"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Setter Property="Focusable" Value="False"/>
                        <Setter Property="IsHitTestVisible" Value="False"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border Background="Transparent"
                                            BorderThickness="0"
                                            SnapsToDevicePixels="False">
                                        <ContentPresenter/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>

            </ListView>

            <!-- Row 2 : Horizontal splitter separating the message list and the bottom input area -->
            <GridSplitter Grid.Row="2"
                          ResizeDirection="Rows"
                          ResizeBehavior="PreviousAndNext"
                          PreviewMouseMove="HorizontalSplitter_PreviewMouseMove"
                          DragDelta="HorizontalSplitter_DragDelta"
                          DragCompleted="HorizontalSplitter_DragCompleted"
                          Height="5"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          Background="Transparent"
                          ShowsPreview="False">

                <!-- Custom template to show a subtle highlight on hover -->
                <GridSplitter.Template>
                    <ControlTemplate TargetType="GridSplitter">
                        <Border x:Name="Grip"
                                Background="Transparent"/>
                        <ControlTemplate.Triggers>
                            
                            <!-- Highlight the splitter only when the mouse is over it -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Grip"
                                        Property="Background"
                                        Value="#1A777777"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </GridSplitter.Template>

                <!-- Disables the splitter entirely when disconnected -->
                <GridSplitter.Style>
                    <Style TargetType="GridSplitter">
                        <Setter Property="Opacity" Value="1"/>
                        <Setter Property="IsHitTestVisible" Value="True"/>

                        <Style.Triggers>
                            
                            <!-- When not connected: splitter becomes invisible and non-interactive -->
                            <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                <Setter Property="Opacity" Value="0"/>
                                <Setter Property="IsHitTestVisible" Value="False"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </GridSplitter.Style>
            </GridSplitter>
        </Grid>

        <!-- Row 3 : Emoji bar -->         
        <Grid x:Name="GrdEmoji"
                Grid.Row="3"
                Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="CmdEmojiPanel"
                    Grid.Column="0"
                    Click="CmdEmojiPanel_Click"
                    Width="32"
                    Height="32"
                    VerticalAlignment="Bottom"
                    Margin="2,0,0,0"
                    Background="Transparent"
                    BorderThickness="0"
                    ToolTip="Emoji bar"
                    TabIndex="7"
                    Cursor="Hand">
                <Image x:Name="ImgEmojiPanel"
                        Source="/Resources/right-arrow.png"
                        Stretch="Uniform"
                        Width="14"/>
            </Button>

            <Image x:Name="imgEncryptionStatus"
                    Grid.Column="1"
                    Width="15"
                    Height="15"
                    VerticalAlignment="Center"
                    Margin="8,0,0,0"
                    Style="{StaticResource EncryptionStatusIconStyle}"/>
        </Grid>

        <!-- Row 3 : Emoji popup -->
        <Popup x:Name="popupEmoji"
                Grid.Row="3"
                DataContext="{Binding}"
                Closed="popupEmoji_Closed"
                Visibility="Collapsed"
                Placement="Top"
                PlacementTarget="{Binding ElementName=BrdMessageInputField}"
                PopupAnimation="Fade"
                StaysOpen="False"
                AllowsTransparency="True"
                HorizontalOffset="0"
                VerticalOffset="-10">

            <Border Background="{DynamicResource BackgroundBrush}"
                    BorderBrush="{DynamicResource PrimaryBrush}"
                    BorderThickness="1"
                    Padding="4"
                    Height="{Binding EmojiPopupHeight}"
                    Width="{Binding ElementName=BrdMessageInputField, Path=ActualWidth}"
                    HorizontalAlignment="Center">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left arrow -->
                    <Button x:Name="CmdScrollLeft"
                            Grid.Column="0"
                            Width="20"
                            Height="20"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            MouseEnter="CmdScrollLeft_MouseEnter"
                            MouseLeave="CmdScrollLeft_MouseLeave"
                            TabIndex="8">
                        <Image Source="/Resources/left-arrow.png" Stretch="Uniform"/>
                    </Button>

                    <!-- Emoji list -->
                    <ScrollViewer x:Name="emojiScrollViewer"
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    MinHeight="48"
                                    Margin="4,0,0,0"
                                    HorizontalScrollBarVisibility="Hidden"
                                    VerticalScrollBarVisibility="Disabled"
                                    CanContentScroll="True"
                                    TabIndex="9">
                        <ItemsControl x:Name="emojiItems"
                                        ItemsSource="{Binding EmojiList}"
                                        TabIndex="10"
                                        Cursor="Hand">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="{Binding DataContext.EmojiButtonSize, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                            Height="{Binding DataContext.EmojiButtonSize, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                            Margin="2,0,0,0"
                                            Padding="0"
                                            Background="{DynamicResource PrimaryBrush}"
                                            Foreground="{DynamicResource ForegroundBrush}"
                                            BorderThickness="0"
                                            VerticalAlignment="Center"
                                            Click="EmojiButton_Click">
                                        <TextBlock Text="{Binding}"
                                                    FontSize="{Binding DataContext.EmojiFontSize, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Right arrow -->
                    <Button x:Name="CmdScrollRight"
                            Grid.Column="2"
                            Width="20"
                            Height="20"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            MouseEnter="CmdScrollRight_MouseEnter"
                            MouseLeave="CmdScrollRight_MouseLeave"
                            TabIndex="11">
                        <Image Source="/Resources/right-arrow.png" Stretch="Uniform"/>
                    </Button>

                </Grid>
            </Border>
        </Popup>

        <!-- Row 4 : Input field -->
        <Grid x:Name="GrdMessageInputField"
              Grid.Row="4"
              MinHeight="34"
              VerticalAlignment="Stretch"
              Margin="0">

            <Border x:Name="BrdMessageInputField"
                        Width="{Binding MessageInputFieldWidth}"
                        Margin="{Binding MessageInputFieldMargin}"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        BorderBrush="{DynamicResource InputBorderBrush}"
                        MinHeight="34"
                        BorderThickness="1"
                        FocusVisualStyle="{x:Null}"
                        CornerRadius="8">

                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Opacity" Value="1"/>
                        <Setter Property="IsEnabled" Value="True"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                <Setter Property="Opacity" Value="0"/>
                                <Setter Property="IsHitTestVisible" Value="False"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>

                    <!-- Input field watermark -->
                    <TextBlock x:Name="TxtMessageInputFieldWatermark"
                               Text="{Binding MessageInputFieldWatermark}"
                               FontSize="{Binding DisplayFontSize}"
                               Margin="6,2,0,0"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Stretch"
                               IsHitTestVisible="False">

                        <!-- Default watermark color (light theme) -->
                        <TextBlock.Foreground>
                            <SolidColorBrush Color="{DynamicResource WatermarkColor}"/>
                        </TextBlock.Foreground>

                        <TextBlock.Style>

                            <Style TargetType="TextBlock" BasedOn="{StaticResource WatermarkFadeStyle}">

                                <!-- Default: hidden -->
                                <Setter Property="Visibility" Value="Collapsed"/>

                                <Style.Triggers>
                                    
                                    <!-- Uses ForegroundBrush when dark theme has been set -->
                                    <DataTrigger Binding="{Binding Source={x:Static settings:Settings.Default}, Path=AppTheme}" Value="dark">
                                        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                                    </DataTrigger>

                                    <!-- Shows watermark when TextBox is empty -->
                                    <DataTrigger Binding="{Binding Text, ElementName=TxtMessageInputField}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>

                                    <!-- Hides watermark when TextBox has text -->
                                    <DataTrigger Binding="{Binding Text, ElementName=TxtMessageInputField}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>

                                    <!-- Hides watermark when TextBox is focused -->
                                    <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=TxtMessageInputField}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>

                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>

                    </TextBlock>

                    <!-- Text input -->
                    <TextBox x:Name="TxtMessageInputField"
                             Grid.Column="0"
                             Text="{Binding MessageToSend, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                             TextWrapping="Wrap"
                             CaretBrush="{DynamicResource ForegroundBrush}"
                             FontSize="{Binding DisplayFontSize}"
                             FocusVisualStyle="{x:Null}"
                             VerticalAlignment="Stretch"
                             VerticalContentAlignment="Top"
                             Background="Transparent"
                             Foreground="{DynamicResource ForegroundBrush}"
                             PreviewKeyDown="TxtMessageInputField_PreviewKeyDown"
                             AcceptsReturn="True"
                             BorderThickness="0"
                             Padding="6,4,6,6"
                             TextChanged="TxtMessageInputField_TextChanged">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>

                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Source={x:Static settings:Settings.Default}, Path=AppTheme}"
                             Value="dark">
                                        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <!-- Send button -->
                    <Button x:Name="CmdSend"
                                Grid.Column="1"
                                Background="Transparent"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Bottom"
                                Click="CmdSend_Click"
                                Width="40"
                                Height="32"
                                BorderThickness="0">
                        <Image Source="/Resources/send.png" Width="18" Height="18"/>
                    </Button>

                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>